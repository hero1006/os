pages = list(map(int, input(&quot;Enter Pages: &quot;).split()))
size = int(input(&quot;No. of Frames: &quot;))

frames, history, faults = [&quot;-&quot;] * size, [], 0
total_pages = len(pages)

print(&quot;\nString | Frames | Status&quot;)
for p in pages:
if p in frames:
status = &quot;Hit&quot;
history.remove(p)
else:
status = &quot;Fault&quot;
faults += 1
if &quot;-&quot; in frames:
idx = frames.index(&quot;-&quot;)
frames[idx] = p
else:
lru_page = history.pop(0)
idx = frames.index(lru_page)
frames[idx] = p
history.append(p)

print(f&quot;{p} | {frames} | {status}&quot;)

print(f&quot;\nTotal Pages: {total_pages} | Faults: {faults} | Ratio: {round(faults/total_pages, 2)}&quot;)

