frames, faults = [&quot;-&quot;] * size, 0
total_pages = len(pages)

print(&quot;\nString | Frames | Status&quot;)
for i in range(total_pages):
p = pages[i]
if p in frames:
status = &quot;Hit&quot;
else:
status = &quot;Fault&quot;
faults += 1
if &quot;-&quot; in frames:
idx = frames.index(&quot;-&quot;)
frames[idx] = p
else:
future = pages[i+1:]
replace_idx, farthest = 0, -1
for j in range(size):
if frames[j] not in future:

replace_idx = j
break
elif future.index(frames[j]) &gt; farthest:
farthest = future.index(frames[j])
replace_idx = j
frames[replace_idx] = p
print(f&quot;{p} | {frames} | {status}&quot;)

