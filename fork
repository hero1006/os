#include<stdio.h>
#include<stdlib.h>
#include<unistd.h>
int main()
{
   Pid_t pid;
   printf("\n Before fork processid=%d", getpid());
   pid= fork();
   if(pid == 0)
   {
       printf("\n After fork, child process ID=%d",getpid());
       }
   else
   {
       printf("\n After fork parent process Id=%d",getpid());
       }
  return 0;
  }
